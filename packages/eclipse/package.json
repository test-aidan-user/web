{
  "name": "@prisma/eclipse",
  "version": "0.0.2",
  "private": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "postcss.config.mjs",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/web",
    "directory": "packages/eclipse"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs",
      "default": "./dist/components/index.mjs"
    },
    "./components/*": {
      "types": "./dist/components/*.d.mts",
      "import": "./dist/components/*.mjs",
      "default": "./dist/components/*.mjs"
    },
    "./styles/*": "./dist/styles/*",
    "./fonts/*": "./dist/static/fonts/*",
    "./postcss.config": "./postcss.config.mjs"
  },
  "scripts": {
    "build": "rimraf dist && pnpm run build:ts && pnpm run build:styles",
    "build:ts": "tsdown --config tsdown.config.ts",
    "build:styles": "mkdir -p dist/styles dist/static/fonts && tailwindcss -i ./src/styles/globals.css -o ./dist/styles/globals.css && cp ./src/styles/fonts.css ./dist/styles/fonts.css && cp ./src/styles/steps.css ./dist/styles/steps.css && cp ./src/static/fonts/* ./dist/static/fonts/",
    "check": "oxfmt . --write && oxlint . --fix",
    "types:check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run types:check"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-collapsible": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "recharts": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "^0.20.3",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
